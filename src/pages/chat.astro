---
import Base from "~/layouts/Base.astro";

const user = Astro.locals.user;
---

<Base title="Chat">
  <style>
    .chat-shell {
      display: flex;
      flex-direction: column;
      gap: 16px;
      min-height: 70vh;
    }
    .chat-log {
      flex: 1;
      display: flex;
      flex-direction: column;
      gap: 12px;
      padding: 16px;
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      overflow-y: auto;
      min-height: 300px;
    }
    .chat-bubble {
      max-width: 85%;
      padding: 10px 14px;
      border-radius: 12px;
      line-height: 1.55;
      word-wrap: break-word;
    }
    .chat-bubble .text h1,
    .chat-bubble .text h2,
    .chat-bubble .text h3 {
      margin: 14px 0 6px;
      font-size: 1.05rem;
      font-weight: 600;
    }
    .chat-bubble .text h1:first-child,
    .chat-bubble .text h2:first-child,
    .chat-bubble .text h3:first-child { margin-top: 0; }
    .chat-bubble .text p { margin: 0 0 10px; }
    .chat-bubble .text p:last-child { margin-bottom: 0; }
    .chat-bubble .text ul,
    .chat-bubble .text ol {
      margin: 6px 0 10px;
      padding-left: 22px;
    }
    .chat-bubble .text li { margin: 2px 0; }
    .chat-bubble .text code {
      font-family: var(--mono);
      font-size: 0.88em;
      background: rgba(255,255,255,0.06);
      padding: 1px 5px;
      border-radius: 4px;
    }
    .chat-bubble .text pre {
      background: #0f1217;
      padding: 10px 12px;
      border-radius: 8px;
      overflow-x: auto;
      margin: 8px 0;
    }
    .chat-bubble .text pre code { background: transparent; padding: 0; }
    .chat-bubble.user .text { white-space: pre-wrap; }
    .chat-bubble.user {
      align-self: flex-end;
      background: var(--accent-soft);
      color: var(--text);
      border: 1px solid var(--accent);
    }
    .chat-bubble.assistant {
      align-self: flex-start;
      background: var(--surface-2);
      color: var(--text);
      border: 1px solid var(--border);
    }
    .chat-bubble .role {
      font-size: 11px;
      text-transform: uppercase;
      letter-spacing: 0.05em;
      color: var(--muted);
      margin-bottom: 4px;
    }
    .tool-use {
      font-family: var(--mono);
      font-size: 12px;
      color: var(--muted);
      padding: 6px 10px;
      background: rgba(255, 255, 255, 0.02);
      border-left: 2px solid var(--accent);
      margin: 4px 0;
      border-radius: 4px;
    }
    .chat-compose {
      display: flex;
      gap: 8px;
    }
    .chat-compose input {
      flex: 1;
    }
    .chat-empty {
      color: var(--muted);
      text-align: center;
      padding: 40px 20px;
    }
  </style>

  <h1>Chat with Warbotics</h1>
  <p class="muted">
    Ask about WPILib, FRC, or the team's own docs. I'll search across the indexed content and cite where I find answers.
  </p>

  <div class="chat-shell">
    <div
      id="chat-log"
      class="chat-log"
      data-user-name={user?.name ?? "You"}
    >
      <div class="chat-empty">Ask a question to get started.</div>
    </div>
    <form id="chat-form" class="chat-compose">
      <input
        id="chat-input"
        type="text"
        placeholder="e.g. How do I set up swerve drive kinematics?"
        autocomplete="off"
        autofocus
      />
      <button class="btn" type="submit" id="chat-send">Send</button>
    </form>
  </div>

  <script>
    import { marked } from "marked";

    marked.setOptions({ gfm: true, breaks: true });

    const log = document.getElementById("chat-log") as HTMLDivElement;
    const form = document.getElementById("chat-form") as HTMLFormElement;
    const input = document.getElementById("chat-input") as HTMLInputElement;
    const send = document.getElementById("chat-send") as HTMLButtonElement;
    const userName = log.dataset.userName || "You";

    interface Part {
      _id: string;
      type: string;
      text?: string;
      state?: string;
    }
    interface Msg {
      id: string;
      role: "user" | "assistant";
      parts: Part[];
    }

    const messages: Msg[] = [];

    function uid(): string {
      return `m-${Date.now()}-${Math.random().toString(36).slice(2, 8)}`;
    }

    function escapeHtml(s: string): string {
      return s.replace(/[&<>"']/g, (c) => ({
        "&": "&amp;", "<": "&lt;", ">": "&gt;", '"': "&quot;", "'": "&#39;",
      }[c] || c));
    }

    function renderBubble(m: Msg): HTMLDivElement {
      const text = m.parts
        .filter((p) => p.type === "text")
        .map((p) => p.text ?? "")
        .join("");
      const tools = m.parts.filter((p) => p.type.startsWith("tool-"));
      const bubble = document.createElement("div");
      bubble.className = `chat-bubble ${m.role}`;
      bubble.dataset.id = m.id;
      const label = m.role === "user" ? escapeHtml(userName) : "Warbotics";
      bubble.innerHTML = `<div class="role">${label}</div>`;
      for (const t of tools) {
        const toolEl = document.createElement("div");
        toolEl.className = "tool-use";
        const name = t.type.replace(/^tool-/, "");
        const status = t.state ?? "running";
        toolEl.textContent = `↳ ${name} (${status})`;
        bubble.appendChild(toolEl);
      }
      const textEl = document.createElement("div");
      textEl.className = "text";
      if (m.role === "assistant" && text) {
        // marked escapes raw HTML by default (no html: true), so <script>
        // tags from the LLM render as literal text.
        textEl.innerHTML = marked.parse(text) as string;
      } else {
        textEl.textContent = text;
      }
      bubble.appendChild(textEl);
      return bubble;
    }

    function render(): void {
      log.innerHTML = "";
      if (messages.length === 0) {
        const empty = document.createElement("div");
        empty.className = "chat-empty";
        empty.textContent = "Ask a question to get started.";
        log.appendChild(empty);
        return;
      }
      for (const m of messages) log.appendChild(renderBubble(m));
      log.scrollTop = log.scrollHeight;
    }

    function upsertMessage(id: string, patch: Partial<Msg>): Msg {
      let m = messages.find((x) => x.id === id);
      if (!m) {
        m = { id, role: patch.role ?? "assistant", parts: [] };
        messages.push(m);
      }
      Object.assign(m, patch);
      render();
      return m;
    }

    function upsertPart(messageId: string, partId: string, patch: Partial<Part>): void {
      const m = messages.find((x) => x.id === messageId);
      if (!m) return;
      let p = m.parts.find((x) => x._id === partId);
      if (!p) {
        p = { _id: partId, type: patch.type ?? "text" };
        m.parts.push(p);
      }
      Object.assign(p, patch);
      render();
    }

    async function sendChat(userText: string): Promise<void> {
      if (!userText.trim()) return;
      const userMsg: Msg = {
        id: uid(),
        role: "user",
        parts: [{ _id: "u0", type: "text", text: userText }],
      };
      messages.push(userMsg);
      render();

      send.disabled = true;
      input.value = "";

      const asstId = uid();
      upsertMessage(asstId, { role: "assistant", parts: [] });

      try {
        const res = await fetch("/api/chat/stream", {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({ messages }),
        });
        if (!res.ok || !res.body) {
          upsertPart(asstId, "err", { type: "text", text: `Error ${res.status}: ${await res.text()}` });
          return;
        }

        const reader = res.body.getReader();
        const decoder = new TextDecoder();
        let buffer = "";
        while (true) {
          const { value, done } = await reader.read();
          if (done) break;
          buffer += decoder.decode(value, { stream: true });
          let newlineIdx: number;
          while ((newlineIdx = buffer.indexOf("\n")) !== -1) {
            const line = buffer.slice(0, newlineIdx).trim();
            buffer = buffer.slice(newlineIdx + 1);
            if (!line) continue;
            const payload = line.startsWith("data: ") ? line.slice(6) : line;
            if (payload === "[DONE]") continue;
            try {
              handleEvent(asstId, JSON.parse(payload));
            } catch { /* ignore malformed lines */ }
          }
        }
      } catch (err) {
        upsertPart(asstId, "err", { type: "text", text: String(err) });
      } finally {
        send.disabled = false;
        input.focus();
      }
    }

    interface StreamEvent {
      type?: string;
      id?: string;
      delta?: string;
      toolCallId?: string;
      toolName?: string;
      name?: string;
      state?: string;
    }

    function handleEvent(asstId: string, event: StreamEvent): void {
      const t = event.type;
      if (!t) return;
      if (t === "text-start") {
        upsertPart(asstId, event.id ?? "t", { type: "text", text: "" });
      } else if (t === "text-delta") {
        const m = messages.find((x) => x.id === asstId);
        if (!m) return;
        const p = m.parts.find((x) => x._id === (event.id ?? "t") && x.type === "text");
        if (p) {
          p.text = (p.text || "") + (event.delta ?? "");
          render();
        }
      } else if (t === "text-end") {
        /* no-op */
      } else if (t.startsWith("tool-input")) {
        /* ignore input streaming events */
      } else if (t.startsWith("tool-output-available") || t === "tool-result") {
        const name =
          event.toolName ?? event.name ?? t.replace(/^tool-output-available-?/, "").replace(/^tool-result-?/, "");
        upsertPart(asstId, `tool-${event.toolCallId ?? event.id ?? name}`, {
          type: `tool-${name}`,
          state: "done",
        });
      } else if (t.startsWith("tool-")) {
        const name = t.replace(/^tool-/, "");
        upsertPart(asstId, `tool-${event.toolCallId ?? event.id ?? name}`, {
          type: `tool-${name}`,
          state: event.state ?? "running",
        });
      }
    }

    form.addEventListener("submit", (e) => {
      e.preventDefault();
      void sendChat(input.value);
    });
  </script>
</Base>
