---
import Base from "~/layouts/Base.astro";
import { isAdmin } from "~/lib/acl";
import { loadConfig } from "~/lib/settings";

const env = Astro.locals.runtime.env as Env;
const user = Astro.locals.user;
const config = await loadConfig(env);

if (!isAdmin(user, config, env)) {
  return new Response("Forbidden — admin-only page.", { status: 403 });
}

const initialJson = JSON.stringify(config, null, 2);
const youAreOwner = user?.email?.toLowerCase() === env.OWNER_EMAIL?.toLowerCase();
---

<Base title="Settings">
  <style is:global>
    .settings-shell {
      display: flex;
      flex-direction: column;
      gap: 20px;
    }
    .settings-card {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      padding: 18px 20px;
    }
    .settings-card h2 {
      margin: 0 0 4px;
      font-size: 1rem;
      letter-spacing: 0.01em;
    }
    .settings-card p.muted { margin: 0 0 14px; }
    .admin-row {
      display: flex;
      align-items: center;
      gap: 10px;
      padding: 8px 12px;
      background: var(--surface-2);
      border: 1px solid var(--border);
      border-radius: 6px;
      margin: 4px 0;
    }
    .admin-row .avatar {
      width: 28px;
      height: 28px;
      border-radius: 50%;
      border: 1px solid var(--border);
      flex-shrink: 0;
      background: var(--bg);
    }
    .admin-row .who {
      flex: 1;
      min-width: 0;
    }
    .admin-row .name { font-weight: 600; }
    .admin-row .sub {
      font-size: 11px;
      color: var(--muted);
      font-family: var(--mono);
    }
    .admin-row .tag-owner {
      font-size: 10px;
      text-transform: uppercase;
      letter-spacing: 0.05em;
      color: var(--accent);
      font-weight: 600;
    }
    .admin-row .unknown {
      color: #ff7b7b;
      font-size: 11px;
      font-style: italic;
    }
    .admin-row .remove {
      background: transparent;
      color: var(--muted);
      border: 1px solid var(--border);
      border-radius: 4px;
      padding: 4px 10px;
      cursor: pointer;
      font-size: 12px;
    }
    .admin-row .remove:hover { color: #ff7b7b; border-color: #ff7b7b; }
    .admin-picker {
      display: flex;
      gap: 8px;
      margin-top: 8px;
    }
    .admin-picker select {
      flex: 1;
      background: var(--surface-2);
      color: var(--text);
      border: 1px solid var(--border);
      border-radius: 6px;
      padding: 8px 10px;
      font: inherit;
    }
    .admin-picker .btn { flex-shrink: 0; }
    .source-row {
      display: grid;
      grid-template-columns: 28px 1fr auto;
      gap: 12px;
      padding: 10px 12px;
      background: var(--surface-2);
      border: 1px solid var(--border);
      border-radius: 6px;
      margin: 6px 0;
      align-items: start;
    }
    .source-row .meta {
      display: flex;
      gap: 10px;
      font-size: 12px;
      color: var(--muted);
      margin-top: 2px;
      flex-wrap: wrap;
    }
    .source-row .meta .kind {
      color: var(--accent);
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 0.04em;
    }
    .source-row textarea {
      grid-column: 2 / 4;
      width: 100%;
      min-height: 90px;
      background: var(--bg);
      color: var(--text);
      border: 1px solid var(--border);
      border-radius: 4px;
      padding: 8px;
      font-family: var(--mono);
      font-size: 12px;
    }
    .source-row .title-row {
      display: flex;
      align-items: center;
      gap: 8px;
    }
    .source-row input[type="text"] {
      flex: 1;
      background: transparent;
      color: var(--text);
      border: 0;
      font: inherit;
      font-weight: 600;
      padding: 2px 0;
    }
    .source-row input[type="checkbox"] { margin: 10px 0 0; }
    .source-row .remove,
    .source-row .reindex {
      background: transparent;
      color: var(--muted);
      border: 1px solid var(--border);
      border-radius: 4px;
      padding: 4px 10px;
      cursor: pointer;
      font-size: 12px;
      white-space: nowrap;
    }
    .source-row .reindex:hover:not(:disabled) {
      color: var(--accent);
      border-color: var(--accent);
    }
    .source-row .remove:hover { color: #ff7b7b; border-color: #ff7b7b; }
    .source-row .row-actions {
      display: flex;
      flex-direction: column;
      gap: 4px;
      align-items: stretch;
    }
    .source-row .reindex-status {
      font-size: 11px;
      color: var(--muted);
      grid-column: 2 / 4;
      margin-top: -2px;
    }
    .source-row .reindex-status.running { color: var(--accent); }
    .source-row .reindex-status.errored { color: #ff7b7b; }
    .source-row .reindex-status.complete { color: #72d191; }
    .source-row .last-indexed {
      grid-column: 2 / 4;
      font-size: 11px;
      color: var(--muted);
      margin-top: -2px;
    }
    .actions {
      display: flex;
      gap: 10px;
      margin-top: 14px;
      align-items: center;
    }
    .status-msg {
      font-size: 13px;
      color: var(--muted);
    }
    .status-msg.error { color: #ff7b7b; }
    .status-msg.ok { color: #72d191; }
    details.raw-json {
      margin-top: 16px;
    }
    details.raw-json > summary {
      cursor: pointer;
      font-size: 12px;
      color: var(--muted);
      text-transform: uppercase;
      letter-spacing: 0.06em;
    }
    details.raw-json textarea {
      width: 100%;
      min-height: 320px;
      margin-top: 10px;
      background: #0b0d11;
      color: var(--text);
      border: 1px solid var(--border);
      border-radius: 6px;
      padding: 12px;
      font-family: var(--mono);
      font-size: 12px;
    }
  </style>

  <h1>Settings</h1>
  <p class="muted">
    Signed in as <strong>{user?.email}</strong>{youAreOwner ? " (owner)" : ""}.
    Changes are stored in <code>r2://warbotics-config/config.json</code>.
  </p>

  <div class="settings-shell" data-owner-email={env.OWNER_EMAIL ?? ""} data-initial={initialJson}>
    <div class="settings-card" id="admins-card">
      <h2>Admins</h2>
      <p class="muted">
        Anyone on this list (plus the bootstrap owner from <code>OWNER_EMAIL</code>)
        can view and edit this page. Admins are identified by Slack user —
        a person has to sign in at least once before they can be added.
      </p>
      <div id="admins-list"></div>
      <div class="admin-picker">
        <select id="admin-picker">
          <option value="">Pick someone who's signed in…</option>
        </select>
        <button type="button" class="btn secondary" id="add-admin">Add admin</button>
      </div>
    </div>

    <div class="settings-card" id="sources-card">
      <h2>Indexed sources</h2>
      <p class="muted">
        Each row corresponds to one AI Search instance and how it's populated.
        Saving updates <code>config.json</code>; re-indexing still runs from
        <code>npm run index:*</code> scripts for now.
      </p>
      <div id="sources-list"></div>
      <button type="button" class="btn secondary" id="add-source">+ Add source</button>
    </div>

    <details class="raw-json">
      <summary>▸ Edit raw JSON</summary>
      <textarea id="raw-editor" spellcheck="false"></textarea>
      <p class="muted" style="margin-top:6px; font-size:12px;">
        Raw mode overrides the form on save. Use it for fields the form doesn't expose.
      </p>
    </details>

    <div class="actions">
      <button type="button" class="btn" id="save-btn">Save</button>
      <button type="button" class="btn secondary" id="reset-btn">Reset</button>
      <span class="status-msg" id="status"></span>
    </div>
  </div>

  <script>
    import type { AppConfig, KnownUser, Source } from "~/lib/settings";

    const shell = document.querySelector(".settings-shell") as HTMLDivElement;
    const initial = JSON.parse(shell.dataset.initial ?? "{}") as AppConfig;
    const ownerEmail = (shell.dataset.ownerEmail ?? "").toLowerCase();

    const adminsList = document.getElementById("admins-list") as HTMLDivElement;
    const adminPicker = document.getElementById("admin-picker") as unknown as HTMLSelectElement;
    const sourcesList = document.getElementById("sources-list") as HTMLDivElement;
    const rawEditor = document.getElementById("raw-editor") as HTMLTextAreaElement;
    const status = document.getElementById("status") as HTMLSpanElement;

    function userByAdminEntry(entry: string, known: KnownUser[]): KnownUser | undefined {
      return known.find((u) => u.slackUserId === entry);
    }

    let state: AppConfig = JSON.parse(JSON.stringify(initial));

    function setStatus(text: string, kind: "" | "ok" | "error" = ""): void {
      status.textContent = text;
      status.className = `status-msg ${kind}`;
    }

    function renderAdmins(): void {
      adminsList.innerHTML = "";
      const known = state.knownUsers ?? [];

      // Render the env OWNER as an always-on row (not stored in state).
      if (ownerEmail) {
        const ownerUser = known.find((u) => (u.email ?? "").toLowerCase() === ownerEmail);
        adminsList.appendChild(renderAdminRow({
          name: ownerUser?.name ?? ownerEmail,
          sub: ownerUser?.slackUserId ? `slack ${ownerUser.slackUserId}` : ownerEmail,
          avatar: ownerUser?.avatar,
          ownerBadge: true,
        }));
      }

      state.admins.forEach((entry, idx) => {
        const u = userByAdminEntry(entry, known);
        // Don't re-render the owner twice if they also happen to be in
        // the admins list by slackUserId.
        if (u && ownerEmail && (u.email ?? "").toLowerCase() === ownerEmail) return;
        adminsList.appendChild(renderAdminRow({
          name: u?.name,
          sub: u?.slackUserId ? `slack ${u.slackUserId}` : undefined,
          avatar: u?.avatar,
          rawEntry: entry,
          onRemove: () => {
            state.admins.splice(idx, 1);
            renderAdmins();
            renderAdminPicker();
            refreshRawEditor();
          },
        }));
      });
    }

    function renderAdminRow(opts: {
      name?: string;
      sub?: string;
      avatar?: string;
      ownerBadge?: boolean;
      rawEntry?: string;
      onRemove?: () => void;
    }): HTMLDivElement {
      const row = document.createElement("div");
      row.className = "admin-row";

      if (opts.avatar) {
        const img = document.createElement("img");
        img.className = "avatar";
        img.src = opts.avatar;
        img.alt = opts.name ?? "";
        row.appendChild(img);
      } else {
        const placeholder = document.createElement("span");
        placeholder.className = "avatar";
        row.appendChild(placeholder);
      }

      const who = document.createElement("div");
      who.className = "who";
      const name = document.createElement("div");
      name.className = "name";
      if (opts.name) {
        name.textContent = opts.name;
      } else {
        name.innerHTML = `<span class="unknown">Unknown user</span>`;
      }
      who.appendChild(name);
      const sub = document.createElement("div");
      sub.className = "sub";
      sub.textContent = opts.sub ?? opts.rawEntry ?? "";
      who.appendChild(sub);
      row.appendChild(who);

      if (opts.ownerBadge) {
        const tag = document.createElement("span");
        tag.className = "tag-owner";
        tag.textContent = "OWNER";
        tag.title = "Set via OWNER_EMAIL env var — always admin, not editable here.";
        row.appendChild(tag);
      } else if (opts.onRemove) {
        const rm = document.createElement("button");
        rm.type = "button";
        rm.className = "remove";
        rm.textContent = "Remove";
        rm.addEventListener("click", opts.onRemove);
        row.appendChild(rm);
      }
      return row;
    }

    function renderAdminPicker(): void {
      adminPicker.innerHTML = "";
      const placeholder = document.createElement("option");
      placeholder.value = "";
      placeholder.textContent = "Pick someone who's signed in…";
      adminPicker.appendChild(placeholder);

      const known = state.knownUsers ?? [];
      const already = new Set(state.admins);
      const ownerInList = known.find((u) => (u.email ?? "").toLowerCase() === ownerEmail);
      if (ownerInList) already.add(ownerInList.slackUserId);

      const candidates = known
        .filter((u) => !already.has(u.slackUserId))
        .sort((a, b) => a.name.localeCompare(b.name));
      for (const u of candidates) {
        const opt = document.createElement("option");
        opt.value = u.slackUserId;
        opt.textContent = u.email ? `${u.name} — ${u.email}` : u.name;
        adminPicker.appendChild(opt);
      }
      if (candidates.length === 0) {
        const opt = document.createElement("option");
        opt.value = "";
        opt.textContent = "— no other users have signed in yet —";
        opt.disabled = true;
        adminPicker.appendChild(opt);
      }
    }

    function renderSources(): void {
      sourcesList.innerHTML = "";
      state.sources.forEach((src, idx) => {
        const row = document.createElement("div");
        row.className = "source-row";

        const enabled = document.createElement("input");
        enabled.type = "checkbox";
        enabled.checked = src.enabled;
        enabled.title = "Enabled";
        enabled.addEventListener("change", () => {
          state.sources[idx].enabled = enabled.checked;
          refreshRawEditor();
        });
        row.appendChild(enabled);

        const center = document.createElement("div");
        const titleRow = document.createElement("div");
        titleRow.className = "title-row";
        const label = document.createElement("input");
        label.type = "text";
        label.value = src.label;
        label.placeholder = "Label";
        label.addEventListener("input", () => {
          state.sources[idx].label = label.value;
          refreshRawEditor();
        });
        titleRow.appendChild(label);
        center.appendChild(titleRow);

        const meta = document.createElement("div");
        meta.className = "meta";
        const kind = document.createElement("span");
        kind.className = "kind";
        kind.textContent = src.kind;
        meta.appendChild(kind);
        const instance = document.createElement("span");
        instance.textContent = `→ ${src.instance}`;
        meta.appendChild(instance);
        const id = document.createElement("span");
        id.textContent = `id: ${src.id}`;
        meta.appendChild(id);
        center.appendChild(meta);

        const ta = document.createElement("textarea");
        ta.value = JSON.stringify(src.config, null, 2);
        ta.spellcheck = false;
        ta.addEventListener("input", () => {
          try {
            state.sources[idx].config = JSON.parse(ta.value);
            ta.style.borderColor = "";
            refreshRawEditor();
          } catch {
            ta.style.borderColor = "#ff7b7b";
          }
        });

        row.appendChild(center);

        const actions = document.createElement("div");
        actions.className = "row-actions";

        const reindexBtn = document.createElement("button");
        reindexBtn.type = "button";
        reindexBtn.className = "reindex";
        reindexBtn.textContent = "Reindex";
        reindexBtn.title =
          src.kind === "github"
            ? `Clone ${(src.config as Record<string, unknown>).repo ?? "…"} and push each file into AI Search.`
            : src.kind === "local-content"
              ? "Local content is indexed by the deploy pipeline — run `npm run index:content` instead."
              : `Reindex kind "${src.kind}" is not implemented yet.`;
        reindexBtn.disabled = src.kind !== "github";
        reindexBtn.addEventListener("click", () => reindexSource(src.id, row));
        actions.appendChild(reindexBtn);

        const rm = document.createElement("button");
        rm.type = "button";
        rm.className = "remove";
        rm.textContent = "Remove";
        rm.addEventListener("click", () => {
          if (!confirm(`Remove source "${src.label}"?`)) return;
          state.sources.splice(idx, 1);
          renderSources();
          refreshRawEditor();
        });
        actions.appendChild(rm);

        row.appendChild(actions);

        if (src.lastIndexedAt) {
          const last = document.createElement("div");
          last.className = "last-indexed";
          last.textContent = `Last indexed: ${new Date(src.lastIndexedAt).toLocaleString()}`;
          row.appendChild(last);
        }

        row.appendChild(ta);
        sourcesList.appendChild(row);
      });
    }

    function refreshRawEditor(): void {
      rawEditor.value = JSON.stringify(state, null, 2);
    }

    function render(): void {
      renderAdmins();
      renderAdminPicker();
      renderSources();
      refreshRawEditor();
    }

    document.getElementById("add-admin")!.addEventListener("click", () => {
      const pick = adminPicker.value;
      if (!pick) return;
      if (state.admins.includes(pick)) return;
      state.admins.push(pick);
      renderAdmins();
      renderAdminPicker();
      refreshRawEditor();
      adminPicker.value = "";
    });

    document.getElementById("add-source")!.addEventListener("click", () => {
      const id = `source-${Date.now()}`;
      const next: Source = {
        id,
        label: "New source",
        kind: "github",
        instance: id,
        enabled: true,
        config: { repo: "owner/repo", branch: "main", sourceDir: "docs", extensions: [".md"] },
      };
      state.sources.push(next);
      renderSources();
      refreshRawEditor();
    });

    // When the user manually edits the raw JSON, feed it back into state
    // so the form fields stay in sync on the next render.
    rawEditor.addEventListener("input", () => {
      try {
        const next = JSON.parse(rawEditor.value) as AppConfig;
        state = next;
        rawEditor.style.borderColor = "";
      } catch {
        rawEditor.style.borderColor = "#ff7b7b";
      }
    });

    async function reindexSource(sourceId: string, row: HTMLDivElement): Promise<void> {
      const btn = row.querySelector(".reindex") as HTMLButtonElement;
      const existing = row.querySelector(".reindex-status");
      if (existing) existing.remove();
      const statusEl = document.createElement("div");
      statusEl.className = "reindex-status running";
      statusEl.textContent = "Starting workflow…";
      row.appendChild(statusEl);
      btn.disabled = true;

      try {
        const kick = await fetch("/api/settings/reindex", {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({ sourceId }),
        });
        if (!kick.ok) throw new Error(`trigger failed: ${kick.status} ${await kick.text()}`);
        const { instanceId } = (await kick.json()) as { instanceId: string };
        statusEl.textContent = `Running (workflow ${instanceId.slice(0, 8)}…)`;

        // Poll status every 5s until terminal.
        const terminal = new Set(["complete", "errored", "terminated"]);
        while (true) {
          await new Promise((r) => setTimeout(r, 5000));
          const res = await fetch(`/api/settings/reindex?id=${encodeURIComponent(instanceId)}`);
          if (!res.ok) throw new Error(`status ${res.status}: ${await res.text()}`);
          const s = (await res.json()) as {
            status: string;
            output?: { stats?: { ok?: number; failed?: number }; totalFiles?: number };
            error?: unknown;
          };
          const state = s.status;
          if (terminal.has(state)) {
            statusEl.classList.remove("running");
            if (state === "complete") {
              statusEl.classList.add("complete");
              const stats = s.output?.stats;
              const total = s.output?.totalFiles;
              const summary = stats
                ? `${stats.ok} uploaded${stats.failed ? `, ${stats.failed} failed` : ""}`
                : "done";
              statusEl.textContent = `✓ Reindex complete — ${summary}${total ? ` (of ${total})` : ""}. Refresh to see the updated timestamp.`;
            } else if (state === "errored") {
              statusEl.classList.add("errored");
              statusEl.textContent = `Reindex failed: ${String(s.error ?? "unknown")}`;
            } else {
              statusEl.classList.add("errored");
              statusEl.textContent = `Reindex terminated.`;
            }
            break;
          }
          statusEl.textContent = `${state}…`;
        }
      } catch (err) {
        statusEl.classList.remove("running");
        statusEl.classList.add("errored");
        statusEl.textContent = `Error: ${String(err)}`;
      } finally {
        btn.disabled = false;
      }
    }

    document.getElementById("reset-btn")!.addEventListener("click", () => {
      if (!confirm("Discard unsaved changes and reset to the last saved config?")) return;
      state = JSON.parse(JSON.stringify(initial));
      render();
      setStatus("Reset to last saved config.");
    });

    document.getElementById("save-btn")!.addEventListener("click", async () => {
      // Prefer the raw editor's JSON if the user touched it; otherwise serialize state.
      const raw = rawEditor.value.trim();
      let body: string;
      if (raw !== JSON.stringify(state, null, 2)) {
        try {
          state = JSON.parse(raw) as AppConfig;
        } catch (err) {
          setStatus(`Invalid JSON in raw editor: ${(err as Error).message}`, "error");
          return;
        }
        body = JSON.stringify(state);
      } else {
        body = JSON.stringify(state);
      }
      setStatus("Saving…");
      try {
        const res = await fetch("/api/settings/config", {
          method: "PUT",
          headers: { "Content-Type": "application/json" },
          body,
        });
        if (!res.ok) {
          const msg = await res.text();
          setStatus(`Save failed (${res.status}): ${msg}`, "error");
          return;
        }
        const saved = (await res.json()) as AppConfig;
        state = saved;
        render();
        setStatus(`Saved at ${saved.updatedAt}.`, "ok");
      } catch (err) {
        setStatus(`Save error: ${String(err)}`, "error");
      }
    });

    render();
  </script>
</Base>
