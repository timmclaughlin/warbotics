---
import Base from "~/layouts/Base.astro";

const user = Astro.locals.user;
const q = Astro.url.searchParams.get("q") ?? "";
---

<Base title="Search">
  <h1>Search</h1>
  <p class="muted">
    Raw keyword search across {user ? "shared docs, WPILib, and your personal notes." : "shared docs and WPILib."}
    Ask a question (or end with "?") and I'll hand it off to <a href="/chat">Chat</a>.
  </p>

  <form id="search-form" method="GET" action="/search" style="margin-bottom: 24px" data-initial-query={q}>
    <input
      type="search"
      name="q"
      value={q}
      autofocus
      placeholder="Keywords — e.g. swerve odometry"
    />
  </form>

  <div id="results" class="card" style="padding: 0; min-height: 200px">
    <p class="muted" style="padding: 16px">Type keywords and press Enter.</p>
  </div>

  <script>
    import { isQuestion } from "~/lib/is-question";

    const form = document.getElementById("search-form") as HTMLFormElement;
    const results = document.getElementById("results") as HTMLDivElement;
    const initialQuery = form.dataset.initialQuery ?? "";

    function handoffToChat(q: string): void {
      window.location.href = `/chat?q=${encodeURIComponent(q)}`;
    }

    async function runSearch(query: string): Promise<void> {
      if (!query) {
        results.innerHTML = '<p class="muted" style="padding:16px">Type a query and press Enter.</p>';
        return;
      }
      results.innerHTML = '<p class="muted" style="padding:16px">Searching…</p>';
      try {
        const res = await fetch(`/api/search?q=${encodeURIComponent(query)}`);
        if (!res.ok) {
          results.innerHTML = `<p style="padding:16px;color:#f88">Error ${res.status}: ${await res.text()}</p>`;
          return;
        }
        interface Hit {
          id: string;
          source?: string;
          title?: string;
          snippet?: string;
          key?: string;
          url?: string;
        }
        const data = (await res.json()) as { results?: Hit[] };
        if (!data.results?.length) {
          results.innerHTML = '<p class="muted" style="padding:16px">No matches.</p>';
          return;
        }
        results.innerHTML = data.results
          .map((r) => {
            const titleHtml = escapeHtml(r.title ?? r.id);
            const titleEl = r.url
              ? `<a href="${escapeHtml(r.url)}">${titleHtml}</a>`
              : titleHtml;
            return `
              <div class="search-result">
                <div class="source">${escapeHtml(r.source ?? "")}${r.key ? ` · ${escapeHtml(r.key)}` : ""}</div>
                <h3 style="margin:4px 0">${titleEl}</h3>
                <p style="margin:0">${escapeHtml(r.snippet ?? "")}</p>
              </div>
            `;
          })
          .join("");
      } catch (err) {
        results.innerHTML = `<p style="padding:16px;color:#f88">${String(err)}</p>`;
      }
    }

    function escapeHtml(s: unknown): string {
      return String(s ?? "").replace(/[&<>"']/g, (c) => ({
        "&": "&amp;", "<": "&lt;", ">": "&gt;", '"': "&quot;", "'": "&#39;",
      }[c] || c));
    }

    form.addEventListener("submit", (e) => {
      e.preventDefault();
      const q = (new FormData(form).get("q")?.toString() ?? "").trim();
      if (!q) return;
      if (isQuestion(q)) {
        handoffToChat(q);
        return;
      }
      const url = new URL(window.location.href);
      url.searchParams.set("q", q);
      window.history.replaceState(null, "", url);
      void runSearch(q);
    });

    if (initialQuery) {
      if (isQuestion(initialQuery)) {
        handoffToChat(initialQuery);
      } else {
        void runSearch(initialQuery);
      }
    }
  </script>
</Base>
