---
import Base from "~/layouts/Base.astro";

const user = Astro.locals.user;
---

<Base title="Search">
  <style is:global>
    .chat-shell {
      display: flex;
      flex-direction: column;
      gap: 16px;
      min-height: 70vh;
    }
    .chat-log {
      flex: 1;
      display: flex;
      flex-direction: column;
      gap: 12px;
      padding: 16px;
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      overflow-y: auto;
      min-height: 300px;
    }
    .chat-bubble {
      max-width: 85%;
      padding: 10px 14px;
      border-radius: 12px;
      line-height: 1.55;
      word-wrap: break-word;
    }
    .chat-bubble .text h1,
    .chat-bubble .text h2,
    .chat-bubble .text h3 {
      margin: 14px 0 6px;
      font-size: 1.05rem;
      font-weight: 600;
    }
    .chat-bubble .text h1:first-child,
    .chat-bubble .text h2:first-child,
    .chat-bubble .text h3:first-child { margin-top: 0; }
    .chat-bubble .text p { margin: 0 0 10px; }
    .chat-bubble .text p:last-child { margin-bottom: 0; }
    .chat-bubble .text ul,
    .chat-bubble .text ol {
      margin: 6px 0 10px;
      padding-left: 22px;
    }
    .chat-bubble .text li { margin: 2px 0; }
    .chat-bubble .text code {
      font-family: var(--mono);
      font-size: 0.88em;
      background: rgba(255,255,255,0.08);
      color: #ffd3a8;
      padding: 1px 6px;
      border-radius: 4px;
    }
    .chat-bubble .text pre {
      background: #0b0d11;
      border: 1px solid var(--border);
      padding: 12px 14px;
      border-radius: 8px;
      overflow-x: auto;
      margin: 10px 0;
      font-size: 0.9em;
      line-height: 1.5;
    }
    .chat-bubble .text pre code {
      background: transparent;
      color: inherit;
      padding: 0;
      font-size: inherit;
    }
    .chat-bubble.user .text { white-space: pre-wrap; }
    .chat-bubble.user {
      align-self: flex-start;
      max-width: 100%;
      background: var(--accent-soft);
      color: var(--text);
      border: 1px solid var(--accent);
    }
    .chat-bubble.assistant {
      align-self: flex-start;
      background: var(--surface-2);
      color: var(--text);
      border: 1px solid var(--border);
    }
    .chat-bubble .role {
      font-size: 11px;
      text-transform: uppercase;
      letter-spacing: 0.05em;
      color: var(--muted);
      margin-bottom: 4px;
    }
    .tool-use {
      display: flex;
      align-items: center;
      flex-wrap: wrap;
      gap: 8px;
      font-size: 12px;
      color: var(--muted);
      padding: 6px 10px;
      background: rgba(255, 255, 255, 0.02);
      border-left: 2px solid var(--accent);
      margin: 4px 0;
      border-radius: 4px;
    }
    .tool-use .tool-name {
      font-weight: 600;
      color: var(--text);
      font-family: var(--mono);
    }
    .tool-use .tool-query {
      font-style: italic;
      color: var(--muted);
    }
    .tool-use .tool-query::before { content: "“"; }
    .tool-use .tool-query::after  { content: "”"; }
    .tool-use .tool-summary {
      color: var(--accent);
    }
    .tool-use .tool-state-pending,
    .tool-use .tool-state-calling,
    .tool-use .tool-state-running {
      color: var(--muted);
      font-style: italic;
    }
    .tool-use .tool-state-error {
      color: #ff7b7b;
    }
    .chat-compose {
      display: flex;
      flex-direction: column;
      gap: 8px;
    }
    .chat-compose-row {
      display: flex;
      gap: 8px;
    }
    .chat-compose-row input { flex: 1; }
    .attachments {
      display: flex;
      flex-wrap: wrap;
      gap: 8px;
    }
    .attachments:empty { display: none; }
    .attachment {
      position: relative;
      border: 1px solid var(--border);
      border-radius: 6px;
      overflow: hidden;
      background: var(--surface-2);
    }
    .attachment img {
      display: block;
      max-width: 96px;
      max-height: 96px;
      object-fit: cover;
    }
    .attachment .remove {
      position: absolute;
      top: 2px;
      right: 2px;
      background: rgba(0, 0, 0, 0.7);
      color: #fff;
      border: 0;
      border-radius: 50%;
      width: 20px;
      height: 20px;
      font-size: 14px;
      line-height: 1;
      cursor: pointer;
      padding: 0;
    }
    .chat-bubble .attachments-in-bubble {
      margin-top: 6px;
    }
    .chat-bubble .attachments-in-bubble img {
      max-width: 240px;
      max-height: 240px;
      border-radius: 6px;
      border: 1px solid var(--border);
    }
    .chat-log.drag-over {
      outline: 2px dashed var(--accent);
      outline-offset: -6px;
    }
    /* Citation chip: small [wpilib] / [team] / etc. pill the user clicks
     * to pop a floating bubble with the title + link. Bubble dismisses
     * on outside click or Escape. Two-click UX: chip → bubble → link. */
    .cite-chip {
      display: inline-block;
      cursor: pointer;
      font-size: 10px;
      padding: 1px 7px;
      border-radius: 999px;
      background: var(--accent-soft);
      color: var(--accent);
      text-transform: uppercase;
      letter-spacing: 0.06em;
      font-weight: 600;
      vertical-align: baseline;
      user-select: none;
      border: 1px solid transparent;
      font-family: inherit;
      line-height: 1.35;
    }
    .cite-chip:hover { border-color: var(--accent); }
    .cite-chip.active {
      background: var(--accent);
      color: #111;
      border-color: var(--accent);
    }
    .cite-popover {
      position: absolute;
      z-index: 1000;
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: 8px;
      padding: 10px 12px;
      box-shadow: 0 8px 24px rgba(0, 0, 0, 0.5);
      max-width: min(420px, calc(100vw - 24px));
      font-size: 13px;
      color: var(--text);
    }
    .cite-popover[hidden] { display: none; }
    .cite-popover .cite-pop-source {
      font-size: 10px;
      text-transform: uppercase;
      letter-spacing: 0.06em;
      color: var(--accent);
      margin-bottom: 4px;
      font-weight: 600;
    }
    .cite-popover a {
      color: var(--link);
      text-decoration: underline;
      word-break: break-word;
    }
    .cite-popover .cite-pop-url {
      font-family: var(--mono);
      font-size: 11px;
      color: var(--muted);
      margin-top: 4px;
      word-break: break-all;
    }
    details.sources {
      margin-top: 12px;
      padding-top: 10px;
      border-top: 1px dashed var(--border);
    }
    details.sources > summary {
      cursor: pointer;
      font-size: 11px;
      text-transform: uppercase;
      letter-spacing: 0.08em;
      color: var(--muted);
      list-style: none;
      display: inline-flex;
      align-items: center;
      gap: 6px;
      padding: 2px 0;
      user-select: none;
    }
    details.sources > summary::-webkit-details-marker { display: none; }
    details.sources > summary::marker { content: ""; }
    details.sources > summary::before {
      content: "▸";
      font-size: 10px;
      transition: transform 0.12s ease;
    }
    details.sources[open] > summary::before { transform: rotate(90deg); }
    details.sources > summary:hover { color: var(--text); }
    details.sources ul {
      list-style: none;
      padding: 0;
      margin: 6px 0 0;
      display: flex;
      flex-direction: column;
      gap: 4px;
    }
    details.sources li {
      font-size: 13px;
      display: flex;
      align-items: baseline;
      gap: 8px;
    }
    details.sources .source-tag {
      font-size: 10px;
      text-transform: uppercase;
      letter-spacing: 0.05em;
      color: var(--accent);
      font-weight: 600;
      flex-shrink: 0;
      min-width: 48px;
    }
    details.sources a {
      color: var(--link);
      word-break: break-word;
    }
    .chat-empty {
      color: var(--muted);
      text-align: center;
      padding: 40px 20px;
    }
    .mode-toggle {
      display: inline-flex;
      align-items: center;
      gap: 0;
      background: var(--surface-2);
      border: 1px solid var(--border);
      border-radius: 999px;
      padding: 3px;
      margin: 0 0 16px;
    }
    .mode-toggle .mode-btn {
      appearance: none;
      background: transparent;
      color: var(--muted);
      border: 0;
      padding: 6px 14px;
      border-radius: 999px;
      font: inherit;
      font-size: 13px;
      cursor: pointer;
      display: inline-flex;
      align-items: center;
      gap: 6px;
    }
    .mode-toggle .mode-btn:hover { color: var(--text); }
    .mode-toggle .mode-btn.active {
      background: var(--accent);
      color: #111;
      font-weight: 600;
    }
    .mode-toggle .mode-hint {
      font-size: 11px;
      color: var(--muted);
      margin-left: 10px;
      text-transform: uppercase;
      letter-spacing: 0.06em;
    }
  </style>

  <h1>Search</h1>
  <p class="muted">
    Ask a full question (or end with "?") for an AI answer with source
    links. Drop in just keywords for a raw search across WPILib, team
    docs, and your personal notes. Paste/drop an image to show the bot
    what you're seeing.
  </p>

  <div class="mode-toggle" role="tablist" aria-label="Mode">
    <button class="mode-btn" data-mode="search" type="button" role="tab" aria-selected="true">🔎 Search</button>
    <button class="mode-btn" data-mode="chat" type="button" role="tab" aria-selected="false">💬 Chat</button>
    <span class="mode-hint" id="mode-hint">auto</span>
  </div>

  <div class="chat-shell">
    <div
      id="chat-log"
      class="chat-log"
      data-user-name={user?.name ?? "You"}
    >
      <div class="chat-empty">Ask, or drop in some keywords to get started.</div>
    </div>
    <form id="chat-form" class="chat-compose">
      <div id="attachments" class="attachments"></div>
      <div class="chat-compose-row">
        <input
          id="chat-input"
          type="text"
          placeholder="Ask, search, or paste an image"
          autocomplete="off"
          autofocus
        />
        <button class="btn secondary" type="button" id="attach-btn" title="Attach image">📎</button>
        <input type="file" id="attach-file" accept="image/*" multiple hidden />
        <button class="btn" type="submit" id="chat-send">Send</button>
      </div>
    </form>
  </div>

  <script>
    import { marked, type Tokens } from "marked";
    import { isQuestion } from "~/lib/is-question";

    marked.setOptions({ gfm: true, breaks: true });

    // Classify an href to a short source tag for the citation chip.
    function citationSource(href: string): string {
      if (!href) return "link";
      if (href.startsWith("https://docs.wpilib.org/")) return "wpilib";
      if (href.startsWith("/docs/") || /warbotics\.[^/]+\/docs\//.test(href)) return "team";
      if (href.startsWith("#")) return "ref";
      try {
        const u = new URL(href, window.location.origin);
        const host = u.hostname.replace(/^www\./, "");
        // Take the registrable name without TLD where obvious: github.com → github
        const parts = host.split(".");
        return parts.length >= 2 ? parts[parts.length - 2] : host;
      } catch {
        return "link";
      }
    }

    function escapeAttr(s: string): string {
      return String(s ?? "")
        .replace(/&/g, "&amp;")
        .replace(/"/g, "&quot;")
        .replace(/</g, "&lt;")
        .replace(/>/g, "&gt;");
    }

    // Render every link in the assistant's markdown as a compact chip.
    // Clicking the chip pops a floating bubble with the title + link;
    // the bubble dismisses on outside click / Escape / scroll.
    marked.use({
      renderer: {
        link(this: unknown, token: Tokens.Link): string {
          const source = citationSource(token.href);
          // Use raw link text (no nested HTML) — bubble renders plain string.
          const title = token.text || token.href;
          return (
            `<button type="button" class="cite-chip"` +
            ` data-href="${escapeAttr(token.href)}"` +
            ` data-title="${escapeAttr(title)}"` +
            ` data-source="${escapeAttr(source)}"` +
            `>${escapeAttr(source)}</button>`
          );
        },
      },
    });

    const log = document.getElementById("chat-log") as HTMLDivElement;
    const form = document.getElementById("chat-form") as HTMLFormElement;
    const input = document.getElementById("chat-input") as HTMLInputElement;
    const send = document.getElementById("chat-send") as HTMLButtonElement;
    const attachBtn = document.getElementById("attach-btn") as HTMLButtonElement;
    const attachInput = document.getElementById("attach-file") as HTMLInputElement;
    const attachmentsEl = document.getElementById("attachments") as HTMLDivElement;
    const modeButtons = Array.from(document.querySelectorAll<HTMLButtonElement>(".mode-btn"));
    const modeHint = document.getElementById("mode-hint") as HTMLSpanElement;
    const userName = log.dataset.userName || "You";

    // Mode state. `manualMode` is set when the user clicks a toggle or once
    // a chat turn has happened; otherwise the effective mode comes from the
    // heuristic (question-shape + image attachment).
    type Mode = "chat" | "search";
    let manualMode: Mode | null = null;
    let chatStarted = false;

    function effectiveMode(): Mode {
      if (manualMode) return manualMode;
      if (chatStarted) return "chat";
      if (pendingAttachments.length > 0) return "chat";
      if (isQuestion(input.value)) return "chat";
      return "search";
    }

    function refreshToggle(): void {
      const m = effectiveMode();
      for (const btn of modeButtons) {
        const isActive = btn.dataset.mode === m;
        btn.classList.toggle("active", isActive);
        btn.setAttribute("aria-selected", String(isActive));
      }
      // "locked" when user has explicitly chosen OR a chat has started;
      // "auto" when the heuristic is still deciding per message.
      modeHint.textContent = manualMode
        ? "locked"
        : chatStarted
          ? "locked (chat in progress)"
          : "auto";
      input.placeholder =
        m === "chat"
          ? "Ask anything, or paste an image"
          : "Keywords to search — or a question to switch to chat";
    }

    for (const btn of modeButtons) {
      btn.addEventListener("click", () => {
        manualMode = btn.dataset.mode as Mode;
        refreshToggle();
        input.focus();
      });
    }

    const MAX_ATTACHMENT_BYTES = 6 * 1024 * 1024;

    interface Part {
      _id: string;
      type: string;
      text?: string;
      state?: string;
      mediaType?: string;
      url?: string;
      filename?: string;
      toolName?: string;
      input?: unknown;
      output?: unknown;
      error?: string;
    }
    interface Msg {
      id: string;
      role: "user" | "assistant";
      parts: Part[];
    }

    interface Attachment {
      mediaType: string;
      url: string;
      filename: string;
    }
    const pendingAttachments: Attachment[] = [];

    const messages: Msg[] = [];

    function uid(): string {
      return `m-${Date.now()}-${Math.random().toString(36).slice(2, 8)}`;
    }

    function escapeHtml(s: string): string {
      return s.replace(/[&<>"']/g, (c) => ({
        "&": "&amp;", "<": "&lt;", ">": "&gt;", '"': "&quot;", "'": "&#39;",
      }[c] || c));
    }

    const TOOL_ICONS: Record<string, string> = {
      search_team_docs: "📘",
      search_wpilib: "📚",
      search_my_notes: "🗒️",
      save_note: "💾",
    };

    function extractQuery(input: unknown): string {
      if (input && typeof input === "object" && "query" in input) {
        const q = (input as { query?: unknown }).query;
        if (typeof q === "string") return q;
      }
      if (input && typeof input === "object" && "title" in input) {
        const t = (input as { title?: unknown }).title;
        if (typeof t === "string") return t;
      }
      return "";
    }

    function summarizeOutput(output: unknown): string {
      if (output == null) return "";
      if (Array.isArray(output)) {
        return `${output.length} hit${output.length === 1 ? "" : "s"}`;
      }
      if (typeof output === "object" && "saved" in output && (output as { saved?: boolean }).saved) {
        return "saved";
      }
      return "";
    }

    function renderToolUse(t: Part): HTMLDivElement {
      const el = document.createElement("div");
      el.className = "tool-use";
      const name = t.toolName ?? (t.type.replace(/^tool-/, "") || "tool");
      const icon = TOOL_ICONS[name] ?? "🔧";
      const state = t.state ?? "pending";
      const query = extractQuery(t.input);
      const summary = state === "done" ? summarizeOutput(t.output) : "";

      const nameEl = document.createElement("span");
      nameEl.className = "tool-name";
      nameEl.textContent = `${icon} ${name}`;
      el.appendChild(nameEl);

      if (query) {
        const qEl = document.createElement("span");
        qEl.className = "tool-query";
        qEl.textContent = query;
        el.appendChild(qEl);
      }

      if (summary) {
        const sEl = document.createElement("span");
        sEl.className = "tool-summary";
        sEl.textContent = summary;
        el.appendChild(sEl);
      } else if (state !== "done") {
        const stEl = document.createElement("span");
        stEl.className = `tool-state-${state}`;
        stEl.textContent = state === "error" ? (t.error ?? "error") : `${state}…`;
        el.appendChild(stEl);
      }

      return el;
    }

    interface SourceRef {
      url: string;
      title: string;
      source: string;
      key?: string;
    }

    function extractSources(parts: Part[]): SourceRef[] {
      const seen = new Set<string>();
      const sources: SourceRef[] = [];
      for (const p of parts) {
        if (!p.type.startsWith("tool-")) continue;
        const out = p.output;
        if (!Array.isArray(out)) continue;
        for (const c of out as Array<Record<string, unknown>>) {
          const url = typeof c.url === "string" ? c.url : undefined;
          if (!url || seen.has(url)) continue;
          seen.add(url);
          sources.push({
            url,
            title: typeof c.title === "string" && c.title ? c.title : (typeof c.key === "string" ? c.key : url),
            source: typeof c.source === "string" ? c.source : (p.toolName ?? ""),
            key: typeof c.key === "string" ? c.key : undefined,
          });
        }
      }
      return sources;
    }

    function sourceTag(source: string): string {
      if (source === "wpilib-docs") return "WPILib";
      if (source === "warbotics-content") return "Team";
      if (source.startsWith("user-")) return "Notes";
      return source;
    }

    function renderSources(sources: SourceRef[]): HTMLDetailsElement | null {
      if (!sources.length) return null;
      const details = document.createElement("details");
      details.className = "sources";
      // Collapsed by default — the user sees just "Sources (N)" and can
      // click to expand. A click anywhere in the summary toggles.
      const summary = document.createElement("summary");
      summary.textContent = `Sources (${sources.length})`;
      details.appendChild(summary);
      const ul = document.createElement("ul");
      for (const s of sources) {
        const li = document.createElement("li");
        const tag = document.createElement("span");
        tag.className = "source-tag";
        tag.textContent = sourceTag(s.source);
        const a = document.createElement("a");
        a.href = s.url;
        a.target = "_blank";
        a.rel = "noopener";
        a.textContent = s.title;
        li.appendChild(tag);
        li.appendChild(a);
        ul.appendChild(li);
      }
      details.appendChild(ul);
      return details;
    }

    function renderBubble(m: Msg): HTMLDivElement {
      const text = m.parts
        .filter((p) => p.type === "text")
        .map((p) => p.text ?? "")
        .join("");
      const tools = m.parts.filter((p) => p.type.startsWith("tool-"));
      const files = m.parts.filter(
        (p) => p.type === "file" && typeof p.url === "string" && (p.mediaType ?? "").startsWith("image/"),
      );
      const bubble = document.createElement("div");
      bubble.className = `chat-bubble ${m.role}`;
      bubble.dataset.id = m.id;
      const label = m.role === "user" ? escapeHtml(userName) : "Warbotics";
      bubble.innerHTML = `<div class="role">${label}</div>`;
      for (const t of tools) {
        bubble.appendChild(renderToolUse(t));
      }
      const textEl = document.createElement("div");
      textEl.className = "text";
      if (m.role === "assistant" && text) {
        // marked escapes raw HTML by default (no html: true), so <script>
        // tags from the LLM render as literal text.
        textEl.innerHTML = marked.parse(text) as string;
      } else {
        textEl.textContent = text;
      }
      bubble.appendChild(textEl);
      if (files.length) {
        const filesEl = document.createElement("div");
        filesEl.className = "attachments-in-bubble";
        for (const f of files) {
          const img = document.createElement("img");
          img.src = f.url!;
          img.alt = f.filename ?? "attached image";
          filesEl.appendChild(img);
        }
        bubble.appendChild(filesEl);
      }
      if (m.role === "assistant") {
        const sourcesEl = renderSources(extractSources(m.parts));
        if (sourcesEl) bubble.appendChild(sourcesEl);
      }
      return bubble;
    }

    function renderAttachments(): void {
      attachmentsEl.innerHTML = "";
      pendingAttachments.forEach((a, idx) => {
        const wrap = document.createElement("div");
        wrap.className = "attachment";
        const img = document.createElement("img");
        img.src = a.url;
        img.alt = a.filename;
        const btn = document.createElement("button");
        btn.type = "button";
        btn.className = "remove";
        btn.textContent = "×";
        btn.title = "Remove";
        btn.addEventListener("click", () => {
          pendingAttachments.splice(idx, 1);
          renderAttachments();
        });
        wrap.appendChild(img);
        wrap.appendChild(btn);
        attachmentsEl.appendChild(wrap);
      });
      refreshToggle();
    }

    function fileToDataUrl(file: File): Promise<string> {
      return new Promise((resolve, reject) => {
        const r = new FileReader();
        r.onload = () => resolve(String(r.result ?? ""));
        r.onerror = () => reject(r.error);
        r.readAsDataURL(file);
      });
    }

    async function attachImageFile(file: File): Promise<void> {
      if (!file.type.startsWith("image/")) return;
      if (file.size > MAX_ATTACHMENT_BYTES) {
        alert(`"${file.name}" is ${(file.size / 1024 / 1024).toFixed(1)}MB — max is ${MAX_ATTACHMENT_BYTES / 1024 / 1024}MB.`);
        return;
      }
      const url = await fileToDataUrl(file);
      pendingAttachments.push({
        mediaType: file.type,
        url,
        filename: file.name || `pasted-${Date.now()}.png`,
      });
      renderAttachments();
    }

    function render(): void {
      log.innerHTML = "";
      if (messages.length === 0) {
        const empty = document.createElement("div");
        empty.className = "chat-empty";
        empty.textContent = "Ask, or drop in some keywords to get started.";
        log.appendChild(empty);
        return;
      }
      for (const m of messages) log.appendChild(renderBubble(m));
      log.scrollTop = log.scrollHeight;
    }

    function upsertMessage(id: string, patch: Partial<Msg>): Msg {
      let m = messages.find((x) => x.id === id);
      if (!m) {
        m = { id, role: patch.role ?? "assistant", parts: [] };
        messages.push(m);
      }
      Object.assign(m, patch);
      render();
      return m;
    }

    function upsertPart(messageId: string, partId: string, patch: Partial<Part>): void {
      const m = messages.find((x) => x.id === messageId);
      if (!m) return;
      let p = m.parts.find((x) => x._id === partId);
      if (!p) {
        p = { _id: partId, type: patch.type ?? "text" };
        m.parts.push(p);
      }
      Object.assign(p, patch);
      render();
    }

    async function sendChat(userText: string): Promise<void> {
      if (!userText.trim() && pendingAttachments.length === 0) return;
      const parts: Part[] = [];
      if (userText.trim()) {
        parts.push({ _id: "u-text", type: "text", text: userText });
      }
      pendingAttachments.forEach((a, i) => {
        parts.push({
          _id: `u-file-${i}`,
          type: "file",
          mediaType: a.mediaType,
          url: a.url,
          filename: a.filename,
        });
      });
      const userMsg: Msg = {
        id: uid(),
        role: "user",
        parts,
      };
      messages.push(userMsg);
      // Attachments are part of this message now — clear the pending tray.
      pendingAttachments.length = 0;
      renderAttachments();
      render();

      send.disabled = true;
      input.value = "";

      const asstId = uid();
      upsertMessage(asstId, { role: "assistant", parts: [] });

      // The server calls convertToModelMessages() (AI SDK v6), which is
      // strict about UIMessage shape. Our in-memory `messages` carry
      // UI-only fields (`_id` on each part, tool parts with `state: "done"`,
      // no `toolCallId`, etc.) that break conversion and cause the model
      // to receive a broken history — leading to an empty response on
      // the second+ turn. Sanitize: strip internal fields, keep only text
      // + file parts. Tool invocations from prior turns are UI decoration;
      // if the model needs those facts again it can re-call the tool.
      interface OutgoingPart {
        type: string;
        text?: string;
        mediaType?: string;
        url?: string;
        filename?: string;
      }
      interface OutgoingMsg {
        id: string;
        role: "user" | "assistant";
        parts: OutgoingPart[];
      }
      const outgoing: OutgoingMsg[] = messages
        .map((m) => {
          const parts: OutgoingPart[] = [];
          for (const p of m.parts) {
            if (p.type === "text" && typeof p.text === "string" && p.text.length) {
              parts.push({ type: "text", text: p.text });
            } else if (
              p.type === "file" &&
              typeof p.url === "string" &&
              typeof p.mediaType === "string"
            ) {
              parts.push({
                type: "file",
                mediaType: p.mediaType,
                url: p.url,
                filename: p.filename,
              });
            }
          }
          return { id: m.id, role: m.role, parts };
        })
        .filter((m) => m.parts.length > 0);

      try {
        const res = await fetch("/api/chat/stream", {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({ messages: outgoing }),
        });
        if (!res.ok || !res.body) {
          upsertPart(asstId, "err", { type: "text", text: `Error ${res.status}: ${await res.text()}` });
          return;
        }

        const reader = res.body.getReader();
        const decoder = new TextDecoder();
        let buffer = "";
        while (true) {
          const { value, done } = await reader.read();
          if (done) break;
          buffer += decoder.decode(value, { stream: true });
          let newlineIdx: number;
          while ((newlineIdx = buffer.indexOf("\n")) !== -1) {
            const line = buffer.slice(0, newlineIdx).trim();
            buffer = buffer.slice(newlineIdx + 1);
            if (!line) continue;
            const payload = line.startsWith("data: ") ? line.slice(6) : line;
            if (payload === "[DONE]") continue;
            try {
              handleEvent(asstId, JSON.parse(payload));
            } catch { /* ignore malformed lines */ }
          }
        }
      } catch (err) {
        upsertPart(asstId, "err", { type: "text", text: String(err) });
      } finally {
        send.disabled = false;
        input.focus();
      }
    }

    interface StreamEvent {
      type?: string;
      id?: string;
      delta?: string;
      toolCallId?: string;
      toolName?: string;
      name?: string;
      state?: string;
      input?: unknown;
      output?: unknown;
      errorText?: string;
    }

    function handleEvent(asstId: string, event: StreamEvent): void {
      const t = event.type;
      if (!t) return;

      if (t === "error") {
        const msg = event.errorText ?? "The model returned an error.";
        upsertPart(asstId, "err", { type: "text", text: `**Error:** ${msg}` });
        return;
      }

      if (t === "text-start") {
        upsertPart(asstId, event.id ?? "t", { type: "text", text: "" });
        return;
      }
      if (t === "text-delta") {
        const m = messages.find((x) => x.id === asstId);
        if (!m) return;
        const p = m.parts.find((x) => x._id === (event.id ?? "t") && x.type === "text");
        if (p) {
          p.text = (p.text || "") + (event.delta ?? "");
          render();
        }
        return;
      }
      if (t === "text-end") return;

      if (t.startsWith("tool-")) {
        const toolId = event.toolCallId ?? event.id;
        if (!toolId) return;
        const partId = `tool-${toolId}`;

        if (t === "tool-input-start") {
          upsertPart(asstId, partId, {
            type: `tool-${event.toolName ?? "unknown"}`,
            state: "calling",
            toolName: event.toolName,
          });
        } else if (t === "tool-input-delta") {
          /* ignore streaming input text */
        } else if (t === "tool-input-available") {
          upsertPart(asstId, partId, {
            type: `tool-${event.toolName ?? "unknown"}`,
            state: "running",
            toolName: event.toolName,
            input: event.input,
          });
        } else if (t === "tool-output-available" || t === "tool-result") {
          upsertPart(asstId, partId, { state: "done", output: event.output });
        } else if (t === "tool-output-error" || t === "tool-input-error") {
          upsertPart(asstId, partId, { state: "error", error: event.errorText ?? "error" });
        }
      }
    }

    interface SearchHit {
      id: string;
      source: string;
      title: string;
      snippet: string;
      url?: string;
      key?: string;
    }

    async function sendSearch(userText: string): Promise<void> {
      const asstId = uid();
      upsertMessage(asstId, { role: "assistant", parts: [] });
      upsertPart(asstId, "search", {
        type: "text",
        text: `**Keyword search: "${userText}"**\n\n_searching…_`,
      });
      try {
        const res = await fetch(`/api/search?q=${encodeURIComponent(userText)}`);
        if (!res.ok) {
          upsertPart(asstId, "search", {
            type: "text",
            text: `Search error ${res.status}: ${await res.text()}`,
          });
          return;
        }
        const data = (await res.json()) as { results: SearchHit[] };
        const lines = [`**Keyword search: "${userText}"**`, ""];
        if (!data.results.length) {
          lines.push("_No matches in the indexed docs. Try phrasing it as a question instead._");
        } else {
          for (const r of data.results.slice(0, 10)) {
            const link = r.url
              ? `[${r.title || r.key || r.id}](${r.url})`
              : `\`${r.title || r.key || r.id}\``;
            const tag = r.source === "wpilib-docs" ? "WPILib" : r.source === "warbotics-content" ? "Team" : "Notes";
            lines.push(`- **${tag}** · ${link}  \n  ${r.snippet}`);
          }
        }
        upsertPart(asstId, "search", { type: "text", text: lines.join("\n") });
      } catch (err) {
        upsertPart(asstId, "search", {
          type: "text",
          text: `Search failed: ${String(err)}`,
        });
      } finally {
        send.disabled = false;
        input.focus();
      }
    }

    form.addEventListener("submit", (e) => {
      e.preventDefault();
      const text = input.value.trim();
      if (!text && pendingAttachments.length === 0) return;

      const mode = effectiveMode();
      if (mode === "chat") {
        chatStarted = true;
        refreshToggle();
        void sendChat(text);
      } else {
        const userMsg: Msg = {
          id: uid(),
          role: "user",
          parts: [{ _id: "u0", type: "text", text }],
        };
        messages.push(userMsg);
        render();
        send.disabled = true;
        input.value = "";
        void sendSearch(text);
        refreshToggle();
      }
    });

    // Live-update the toggle as the user types or attaches images so they
    // can see ahead of time which mode their next send will use.
    input.addEventListener("input", refreshToggle);

    // Paste images straight from the clipboard (screenshots, copied images).
    form.addEventListener("paste", async (e: ClipboardEvent) => {
      const items = e.clipboardData?.items;
      if (!items) return;
      const imageItems = Array.from(items).filter((it) => it.kind === "file" && it.type.startsWith("image/"));
      if (!imageItems.length) return;
      e.preventDefault();
      for (const it of imageItems) {
        const file = it.getAsFile();
        if (file) await attachImageFile(file);
      }
    });

    // Drag-and-drop images onto the log.
    ["dragenter", "dragover"].forEach((name) => {
      log.addEventListener(name, (e) => {
        const dt = (e as DragEvent).dataTransfer;
        if (dt && Array.from(dt.types).includes("Files")) {
          e.preventDefault();
          log.classList.add("drag-over");
        }
      });
    });
    ["dragleave", "drop"].forEach((name) => {
      log.addEventListener(name, () => log.classList.remove("drag-over"));
    });
    log.addEventListener("drop", async (e) => {
      const files = (e as DragEvent).dataTransfer?.files;
      if (!files?.length) return;
      e.preventDefault();
      for (const f of Array.from(files)) await attachImageFile(f);
    });

    // Manual 📎 button → hidden <input type="file">.
    attachBtn.addEventListener("click", () => attachInput.click());
    attachInput.addEventListener("change", async () => {
      const files = attachInput.files;
      if (!files?.length) return;
      for (const f of Array.from(files)) await attachImageFile(f);
      attachInput.value = "";
    });

    // Initial paint so the toggle reflects "auto / search" on load.
    refreshToggle();

    // Citation popover: one floating bubble shared across all chips.
    // Click chip → show near it with title + link. Click outside or
    // press Escape → hide.
    let citePopover: HTMLDivElement | null = null;
    function ensurePopover(): HTMLDivElement {
      if (!citePopover) {
        citePopover = document.createElement("div");
        citePopover.className = "cite-popover";
        citePopover.hidden = true;
        document.body.appendChild(citePopover);
      }
      return citePopover;
    }
    function hideCitePopover(): void {
      if (citePopover) citePopover.hidden = true;
      document.querySelectorAll(".cite-chip.active").forEach((el) => el.classList.remove("active"));
    }
    function showCitePopover(chip: HTMLElement): void {
      const href = chip.dataset.href ?? "#";
      const title = chip.dataset.title ?? href;
      const source = chip.dataset.source ?? "";
      const p = ensurePopover();

      p.innerHTML = "";
      if (source) {
        const srcEl = document.createElement("div");
        srcEl.className = "cite-pop-source";
        srcEl.textContent = source;
        p.appendChild(srcEl);
      }
      const titleEl = document.createElement("a");
      titleEl.href = href;
      titleEl.target = "_blank";
      titleEl.rel = "noopener";
      titleEl.textContent = title;
      p.appendChild(titleEl);
      // Raw URL under the title — scannable even without clicking through.
      const urlEl = document.createElement("div");
      urlEl.className = "cite-pop-url";
      urlEl.textContent = href;
      p.appendChild(urlEl);

      // Show first so we can measure it, then position.
      p.hidden = false;
      document.querySelectorAll(".cite-chip.active").forEach((el) => el.classList.remove("active"));
      chip.classList.add("active");

      const chipRect = chip.getBoundingClientRect();
      const popRect = p.getBoundingClientRect();
      const margin = 8;
      let top = chipRect.bottom + window.scrollY + 4;
      let left = chipRect.left + window.scrollX;
      if (left + popRect.width > window.scrollX + window.innerWidth - margin) {
        left = window.scrollX + window.innerWidth - popRect.width - margin;
      }
      if (left < margin) left = margin;
      // If there's no room below the chip, flip above.
      if (chipRect.bottom + popRect.height + 8 > window.innerHeight) {
        top = chipRect.top + window.scrollY - popRect.height - 4;
      }
      p.style.top = `${top}px`;
      p.style.left = `${left}px`;
    }

    document.addEventListener("click", (e) => {
      const target = e.target as HTMLElement;
      const chip = target.closest<HTMLElement>(".cite-chip");
      if (chip) {
        e.preventDefault();
        // If the same chip is already active, toggle off.
        if (chip.classList.contains("active")) {
          hideCitePopover();
        } else {
          showCitePopover(chip);
        }
        return;
      }
      if (citePopover && !citePopover.hidden && !target.closest(".cite-popover")) {
        hideCitePopover();
      }
    });
    document.addEventListener("keydown", (e) => {
      if (e.key === "Escape") hideCitePopover();
    });
    // Hide on scroll-in-log so the popover doesn't detach visually from
    // its chip as the chat log scrolls.
    log.addEventListener("scroll", hideCitePopover, { passive: true });
    window.addEventListener("resize", hideCitePopover);

    // Accept an initial query via ?q=… and auto-submit. Clear the param
    // so reload doesn't duplicate.
    const params = new URL(window.location.href).searchParams;
    const initialQ = params.get("q")?.trim() ?? "";
    if (initialQ) {
      input.value = initialQ;
      const cleanUrl = new URL(window.location.href);
      cleanUrl.searchParams.delete("q");
      history.replaceState(null, "", cleanUrl.toString());
      form.requestSubmit();
    }
  </script>
</Base>
